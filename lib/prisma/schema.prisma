generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- BETTER-AUTH TABLES ---

model User {
  id            String    @id @default(uuid(7))
  email         String    @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(HR)
  sessions      Session[]
  accounts      Account[]

  // Traçabilité ERP
  attendanceLogs AttendanceRecord[]

  @@map("user")
}

enum UserRole {
  ADMIN
  HR
  SUPERVISOR
}

model Session {
  id        String   @id @default(uuid(7))
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid(7))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- EXLS BUSINESS TABLES ---

model Employee {
  id        String   @id @default(uuid(7))
  firstName String
  lastName  String
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())

  missions   MissionEmployee[]
  attendance AttendanceRecord[]

  @@map("employees")
}

model Client {
  id        String    @id @default(uuid(7))
  name      String
  contact   String?
  missions  Mission[]
  createdAt DateTime  @default(now())

  @@map("clients")
}

model Mission {
  id             String   @id @default(uuid(7))
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Utilisation d'un DateTime complet pour simplifier les comparaisons temporelles
  plannedStartAt DateTime 
  status         String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  
  employees  MissionEmployee[]
  attendance AttendanceRecord[]
  createdAt  DateTime @default(now())

  @@index([clientId, plannedStartAt])
  @@map("missions")
}

model MissionEmployee {
  missionId  String
  employeeId String
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([missionId, employeeId])
  @@map("mission_employees")
}

model AttendanceRecord {
  id          String   @id @default(uuid(7))
  missionId   String
  employeeId  String
  arrivedAt   DateTime // Date + Heure exacte du pointage
  
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([missionId, employeeId])
  @@map("attendance_records")
}

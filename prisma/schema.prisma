generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid(7))
  email         String    @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(HR)
  sessions      Session[]
  accounts      Account[]

  // Traçabilité ERP
  attendanceLogs AttendanceRecord[]

  @@map("user")
}

enum UserRole {
  ADMIN
  HR
  SUPERVISOR
}

enum MissionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Session {
  id        String   @id @default(uuid(7))
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid(7))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- EXLS BUSINESS TABLES ---

model Employee {
  id        String   @id @default(uuid(7))
  firstName String
  lastName  String
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())

  missions   MissionEmployee[]
  attendance AttendanceRecord[]

  @@map("employees")
}

model MissionEmployee {
  missionId  String
  employeeId String
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([missionId, employeeId])
  @@map("mission_employees")
}

model Client {
  id        String    @id @default(uuid(7))
  name      String
  contact   String?
  
  sites     Site[]    // Un client possède plusieurs sites
  missions  Mission[] 
  
  createdAt DateTime  @default(now())
  deletedAt DateTime? 

  @@map("clients")
}

// NOUVELLE TABLE : SITE
model Site {
  id        String   @id @default(uuid(7))
  name      String   // ex: "Agence Centrale", "Entrepôt Nord"
  address   String?
  
  // Clé étrangère vers le Client
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  // Relations descendantes
  missions   Mission[]
  attendance AttendanceRecord[] // Lien direct pour les requêtes géographiques rapides
  
  createdAt DateTime  @default(now())
  deletedAt DateTime? // Soft delete

  @@map("sites")
}

model Mission {
  id             String   @id @default(uuid(7))
  
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  
  plannedStartAt DateTime 
  status         MissionStatus @default(PLANNED) 
  
  employees      MissionEmployee[]
  attendance     AttendanceRecord[]
  createdAt      DateTime @default(now())

  // L'index intègre désormais le site pour des recherches optimisées
  @@index([siteId, plannedStartAt])
  @@map("missions")
}
model AttendanceRecord {
  id          String   @id @default(uuid(7))
  missionId   String
  employeeId  String
  
  siteId      String
  
  arrivedAt   DateTime 
  departedAt  DateTime? // Ajout anticipé pour la fin de service
  
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Restrict)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // Double contrainte d'unicité pour éviter le double pointage d'un agent sur une même mission
  @@unique([missionId, employeeId]) 
  @@index([arrivedAt(sort: Desc)])
  @@index([siteId, arrivedAt]) // Index géographique hyper-rapide
  
  @@map("attendance_records")
}

// --- NOUVELLES TABLES POUR LES PRODUITS ET IMAGES ---

model Product {
  id          String         @id @default(uuid())
  name        String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  slug        String         @unique // Pour des URL SEO-friendly
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProductImage[] // Relation vers les images du produit

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   // L'URL publique de l'image sur Supabase Storage
  altText   String?  // Texte alternatif pour l'accessibilité
  isPrimary Boolean  @default(false) // Pour l'image principale/miniature
  order     Int      @default(0) // Pour l'ordre d'affichage des images
  createdAt DateTime @default(now())

  @@unique([productId, url]) // S'assure qu'une image n'est pas ajoutée deux fois au même produit
  @@map("product_images")
}
}
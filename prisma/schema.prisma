
generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid(7))
  email         String    @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(MANAGER)
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]

  // Traçabilité ERP
  attendanceLogs AttendanceRecord[]

  @@map("user")
}

enum UserRole {
  ADMIN
  MANAGER
  SUPERVISOR
}

enum MissionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Session {
  id        String   @id @default(uuid(7))
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid(7))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Client {
  id        String    @id @default(uuid(7))
  name      String
  contact   String?

  metadata  Json? // Stockage de données spécifiques au client, comme les préférences de notification, les configurations d'API, etc.

  sites     Site[]    // Un client possède plusieurs sites
  missions  Mission[] 
  
  creePar     String 
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? 

  @@map("clients")
  // schema.prisma



}

model Site {
  id        String   @id @default(uuid(7))
  name      String   // ex: "Agence Centrale", "Entrepôt Nord"
  address   String?
  
  // Clé étrangère vers le Client
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  // Relations descendantes
  missions   Mission[]
  attendance AttendanceRecord[] // Lien direct pour les requêtes géographiques rapides
  
  createdAt DateTime  @default(now())
  deletedAt DateTime? // Soft delete

  @@map("sites")
}

model Mission {
  id             String   @id @default(uuid(7))
  
  agents         MissionAgent[] // Many-to-many relationship with Agent

  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  shift          ShiftType
  
  plannedStartAt DateTime 
  status         MissionStatus @default(PLANNED) 
  
  attendance     AttendanceRecord[]
  createdAt      DateTime @default(now())

  // L'index intègre désormais le site pour des recherches optimisées
  @@index([siteId, plannedStartAt])
  @@map("missions")
}

model AttendanceRecord {
  id          String   @id @default(uuid(7))
  missionId   String
  agentId   String
  
  siteId      String
  
  arrivedAt   DateTime 
  departedAt  DateTime? // Ajout anticipé pour la fin de service
  
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Restrict)
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // Double contrainte d'unicité pour éviter le double pointage d'un agent sur une même mission
  @@unique([missionId, agentId]) 
  @@index([arrivedAt(sort: Desc)])
  @@index([siteId, arrivedAt]) // Index géographique hyper-rapide
  
  @@map("attendance_records")
}

model AuditLog {
  id          String   @id @default(uuid(7))
  userId      String
  action      String   // ex: "CREATE_MISSION", "UPDATE_ATTENDANCE"
  details     Json?    // Détails spécifiques à l'action, stockés en JSON
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Agent {
  id            String    @id @default(uuid(7))
  nom           String
  postnom       String?
  prenom        String
  contact1      String
  contact2      String?
  adresseDomicile String
  dateNaissance DateTime
  dateDebutService DateTime
  observation   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  missions      MissionAgent[] // Many-to-many relationship with Mission
  attendance    AttendanceRecord[] // Relation to attendance records for this agent

  // Documents de l'agent
  formulaire    Boolean @default(false)
  photoUrl      String? // URL de la photo de profil de l'agent
  cv            Boolean @default(false)
  carte         Boolean @default(false)
  diplome       Boolean @default(false)
  documents     Document[] // Relation vers les documents de l'agent
  
  @@map("agents")
}

model Document {
  id          String   @id @default(uuid(7))
  agentId     String
  type        DocumentType
  url         String   // URL du document stocké (ex: S3, Cloudinary)
  uploadedAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("documents")
}

enum DocumentType {
  CV
  CARTE_IDENTITE
  DIPLOME
  AUTRE
}

enum ShiftType {
  DAY_12H
  NIGHT_12H
  FULL_24H
}

model MissionAgent {
  missionId String
  agentId   String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  agent     Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  assignedAt DateTime @default(now())

  @@id([missionId, agentId]) // Primary key for the join table
  @@unique([missionId, agentId]) // Ensures unique combination of mission and agent
  @@map("mission_agents")
}
